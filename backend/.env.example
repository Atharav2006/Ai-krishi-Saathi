# AI Krishi Saathi Environment Variables

# --- Core App ---
ENV=development
SECRET_KEY=generate-a-secure-random-secret-key-in-production

# --- Database ---
# Replace with actual PostgreSQL connection URL in production
DATABASE_URL=postgresql://user:password@localhost:5432/krishi_db

# --- External Services ---
WEATHER_API_KEY=your_openweather_api_key_here

# --- ML Model Configuration ---
MODEL_VERSION_TAG=latest
